{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "esnext",
    "sourceMap": true,
    "importHelpers": true,
    "module": "esnext",
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "outDir": "build",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "rootDir": ".",
    "allowJs": true,
    "paths": {
      "@depl/convert-sitemap-to-domain-models": [
        "packages/convert-sitemap-to-domain-models/src/index.ts"
      ],
      "@depl/olddispatcher": ["packages/olddispatcher/src/index.ts"],
      "@depl/unpacker": ["packages/unpacker/src/index.ts"],
      "@depla/generate-code": ["packages/generate-code/src/index.ts"],
      "@depla/generate-stack": ["packages/generate-stack/src/index.ts"],
      "@depla/ioc": ["packages/ioc/src/index.ts"],
      "@depla/utils-astro-collections-facade": [
        "packages/utils/astro-collections-facade/src/index.ts"
      ],
      "@depla/utils-astro-plugin-inject": [
        "packages/utils/astro-plugin-inject/src/index.ts"
      ],
      "@depla/utils-astro-plugin-predict-reading-time": [
        "packages/utils/astro-plugin-predict-reading-time/src/index.ts"
      ],
      "@depla/utils-db": ["packages/utils/db/src/index.ts"],
      "create-depla": ["packages/create-depla/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
