{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "esnext",
    "sourceMap": true,
    "importHelpers": true,
    "module": "esnext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "build",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "rootDir": ".",
    "allowJs": true,
    "paths": {
      "@depl/convert-sitemap-to-domain-models": [
        "packages/convert-sitemap-to-domain-models/src/index.ts"
      ],
      "@depl/olddispatcher": ["packages/olddispatcher/src/index.ts"],
      "@depl/unpacker": ["packages/unpacker/src/index.ts"],
      "@depla/astro-image": ["packages/astro-image/src/index.ts"],
      "@depla/generate-code": ["packages/generate-code/src/index.ts"],
      "@depla/generate-stack": ["packages/generate-stack/src/index.ts"],
      "@depla/ioc": ["packages/ioc/src/index.ts"],
      "@depla/utils-astro-collections-facade": [
        "packages/utils/astro-collections-facade/src/index.ts"
      ],
      "@depla/utils-astro-plugin-inject": [
        "packages/utils/astro-plugin-inject/src/index.ts"
      ],
      "@depla/utils-astro-plugin-predict-reading-time": [
        "packages/utils/astro-plugin-predict-reading-time/src/index.ts"
      ],
      "@depla/utils-db": ["packages/utils/db/src/index.ts"],
      "@depla/utils-environment": ["packages/utils/environment/src/index.ts"],
      "@depla/utils-image": ["packages/utils/image/src/index.ts"],
      "@depla/utils-route": ["packages/utils/route/src/index.ts"],
      "@depla/utils-time": ["packages/utils/time/src/index.ts"],
      "@depla/utils-url": ["packages/utils/url/src/index.ts"],
      "create-depla": ["packages/create-depla/src/index.ts"],
      "depla": ["packages/depla/src/index.ts"],
      "depla-stack-nx-astro-unocss": [
        "packages/depla-stack-nx-astro-unocss/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
