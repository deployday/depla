// This file is injected into every SSR module by astro
// see astro.config.ts
import { app as APP_FOR_SEED } from '<%= scope %>/website/app';

export const SSR_BOOTSTRAP = () => {
  // seed all the entities before Application consumes them via ORM
  <% entities.forEach(function(entity){ %>
  APP_FOR_SEED.<%= entity %>.seed();
  <% }); %>
}
