import { findImage } from '<%= scope %>/shared/util/image';
import {
  getCanonical,
  cleanSlug,
  createPath,
  generatePermalink,
} from '<%= scope %>/shared/util/url';
import { <%= entity.nameCamelCase %> as <%= entity.nameCamelCase %>Model } from '@prisma/client';
import { config } from './config';
import { <%= entity.nameCamelCase %>Seed } from './seed';

export function <%= entity.nameCamelCase %>(app) {
  const { <%= entity.nameCamelCase %> }: { <%= entity.nameCamelCase %>: <%= entity.nameCamelCase %>Model } = app.db;

  return Object.assign(<%= entity.nameCamelCase %>, {
    config,
    seed: () => <%= entity.nameCamelCase %>Seed.call(app),
    /**
     * Signup the first user and create a new team of one. Return the User with
     * a full name and without a password
     */
    get<%= entity.nameCamelCase %>TaxonomyPermalink(taxonomy, taxonomyValue) {
      const pathname = config.taxonomies[taxonomy]?.pathname;
      return createPath(pathname, taxonomyValue);
    },
    get<%= entity.nameCamelCase %>Permalink(link) {
      return createPath(app?.config?.basePathname, link);
    },
    get<%= entity.nameCamelCase %>ListPermalink() {
      return createPath(app?.config?.basePathname, config?.list?.pathname);
    },
    async find<%= entity.namePluralCamelCase %>BySlugs(slugs: Array<string>): Promise<Array<<%= entity.nameCamelCase %>>> {
      if (!Array.isArray(slugs)) return [];

      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany();

      return slugs.reduce(function (r: Array<<%= entity.nameCamelCase %>>, slug: string) {
        <%= entity.namePlural %>.some(function (<%= entity.nameCamelCase %>: <%= entity.nameCamelCase %>) {
          return slug === <%= entity.nameCamelCase %>.slug && r.push(<%= entity.nameCamelCase %>);
        });
        return r;
      }, []);
    },
    async find<%= entity.namePluralCamelCase %>ByIds(ids: Array<string>): Promise<Array<<%= entity.nameCamelCase %>>> {
      if (!Array.isArray(ids)) return [];

      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany();

      return ids.reduce(function (r: Array<<%= entity.nameCamelCase %>>, id: string) {
        <%= entity.namePlural %>.some(function (<%= entity.nameCamelCase %>: <%= entity.nameCamelCase %>) {
          return id === <%= entity.nameCamelCase %>.id && r.push(<%= entity.nameCamelCase %>);
        });
        return r;
      }, []);
    },
    async first<%= entity.nameCamelCase %>(): Promise<<%= entity.nameCamelCase %>Model> {
      return <%= entity.nameCamelCase %>.findUnique({ where: { id: 4 } });
    },
    async findLatest<%= entity.namePluralCamelCase %>({
      count,
    }: {
      count?: number;
    }): Promise<Array<<%= entity.nameCamelCase %>Model>> {
      const _count = count || 4;
      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany();

      return <%= entity.namePlural %> ? <%= entity.namePlural %>.slice(0, _count) : [];
    },
    async get<%= entity.nameCamelCase %>ListStaticPaths({ paginate }) {
      if (config?.disabled || config?.list?.disabled) return [];
      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany({
        include: {
          tags: true,
        },
        // select: {
        //   title: true,
        //   slug: true,
        //   content: true,
        //   tags: {
        //     select: {
        //       name: true,
        //     },
        //   },
        // },
      });
      return paginate(<%= entity.namePlural %>, {
        params: { blog: config?.list?.pathname || undefined },
        pageSize: config.itemsPerPage,
      });
    },
    async get<%= entity.nameCamelCase %>ViewStaticPaths() {
      if (config?.disabled || config?.item?.disabled) return [];
      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany();
      return await Promise.all(
        <%= entity.namePlural %>.map(async (<%= entity.nameCamelCase %>) => {
          const entry = await app.collections.getEntryBySlug('<%= entity.nameCamelCase %>', <%= entity.nameCamelCase %>.slug);
          for (const prop in entry) {
            if (Object.hasOwn(entry, prop)) {
              <%= entity.nameCamelCase %>[prop] = entry[prop];
            }
          }
          const { Content } = await entry.render();
          <%= entity.nameCamelCase %>.Content = Content;
          return {
            params: {
              blog: <%= entity.nameCamelCase %>.permalink,
            },
            props: { <%= entity.nameCamelCase %>: <%= entity.nameCamelCase %> },
          };
        })
      );
    },
    getMetaByPage(page) {
      const currentPage = page.currentPage ?? 1;

      return {
        title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
        description: app?.config?.description,
        noindex: config?.list?.noindex || currentPage > 1,
        ogType: 'blog',
      };
    },
    async getMetaBy<%= entity.nameCamelCase %>(<%= entity.nameCamelCase %>) {
      const url = getCanonical(
        createPath(config.pathname, <%= entity.nameCamelCase %>.permalink),
        app?.config?.origin
      );
      return {
        title: <%= entity.nameCamelCase %>.title,
        description: <%= entity.nameCamelCase %>.description,
        canonical: <%= entity.nameCamelCase %>.canonical || url,
        image: await findImage(<%= entity.nameCamelCase %>.image),
        noindex: config?.item?.noindex,
        ogType: 'article',
      };
    },
    async get<%= entity.nameCamelCase %>CategoryListStaticPaths({ paginate }) {
      if (config?.disabled || config.taxonomies.category?.disabled) return [];

      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany();
      const categories = new Set();
      <%= entity.namePlural %>.map((<%= entity.nameCamelCase %>) => {
        typeof <%= entity.nameCamelCase %>.category === 'string' &&
          categories.add(<%= entity.nameCamelCase %>.category.toLowerCase());
      });

      return Array.from(categories).map((category: string) =>
        paginate(
          <%= entity.namePlural %>.filter(
            (<%= entity.nameCamelCase %>) =>
              typeof <%= entity.nameCamelCase %>.category === 'string' &&
              category === <%= entity.nameCamelCase %>.category.toLowerCase()
          ),
          {
            params: {
              category: category,
              blog: config.taxonomies.category.pathname || undefined,
            },
            pageSize: config.taxonomies.category.itemsPerPage,
            props: { category },
          }
        )
      );
    },
    get<%= entity.nameCamelCase %>CategoryMetaByPage(page, category) {
      const currentPage = page.currentPage ?? 1;
      const meta = {
        title: `Category'${category}' ${
          currentPage > 1 ? ` — Page ${currentPage}` : ''
        }`,
        description: app?.config?.description,
        noindex: config.taxonomies.category?.noindex,
      };
      return meta;
    },

    async get<%= entity.nameCamelCase %>TagListStaticPaths({ paginate }) {
      if (config?.disabled || config.taxonomies.tag?.disabled) return [];

      const <%= entity.namePlural %> = await <%= entity.nameCamelCase %>.findMany({
        include: {
          tags: true,
        },
      });
      const tags = new Set();
      <%= entity.namePlural %>.map((<%= entity.nameCamelCase %>) => {
        Array.isArray(<%= entity.nameCamelCase %>.tags) &&
          <%= entity.nameCamelCase %>.tags.map((tag) => tags.add(tag.name.toLowerCase()));
      });

      return Array.from(tags).map((tag: string) =>
        paginate(
          <%= entity.namePlural %>.filter(
            (<%= entity.nameCamelCase %>) =>
              Array.isArray(<%= entity.nameCamelCase %>.tags) &&
              <%= entity.nameCamelCase %>.tags.find((elem) => elem.name.toLowerCase() === tag)
          ),
          {
            params: {
              tag: tag,
              blog: config.taxonomies.tag.pathname || undefined,
            },
            pageSize: config.taxonomies.tag.itemsPerPage,
            props: { tag },
          }
        )
      );
    },

    get<%= entity.nameCamelCase %>TagMetaByPage(page, tag) {
      const currentPage = page.currentPage ?? 1;
      const meta = {
        title: `<%= entity.namePluralCamelCase %> by tag '${tag}'${
          currentPage > 1 ? ` — Page ${currentPage} ` : ''
        }`,
        description: app?.config?.description,
        noindex: config.taxonomies.tag?.noindex,
      };
      return meta;
    },
  });
}
