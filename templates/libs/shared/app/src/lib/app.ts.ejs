import { Container } from '<%= scope %>/shared/util/ioc';

import { provider as environmentProvider } from '<%= scope %>/shared/util/environment';
import { provider as configProvider } from '<%= scope %>/website/config';
import { provider as routeProvider } from '<%= scope %>/shared/util/route';
import { provider as dbProvider } from '<%= scope %>/shared/util/db';

<% entities.forEach(function(entity){ %>
import { provider as <%= entity %>Provider } from '<%= scope %>/shared/entities/<%= entity %>';
<% }); %>

export const app = new Container();

const providers = [
  environmentProvider,
  configProvider,
  routeProvider,
  dbProvider,
  <% entities.forEach(function(entity){ %>
    <%= entity %>Provider(app);
  <% }); %>
]
providers.forEach((provider) => provider(app))
