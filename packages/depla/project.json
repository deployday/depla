{
  "name": "depla",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/depla/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/build/packages/depla"],
      "options": {
        "commands": [
          {
            "command": "echo '`depla` npm package build task is done'"
          }
        ],
        "parallel": false
      }
    },
    "build-base": {
      "executor": "@nrwl/js:tsc",
      "options": {
        "main": "packages/depla/src/index.ts",
        "updateBuildableProjectDepsInPackageJson": true,
        "buildableProjectDepsInPackageJsonType": "dependencies"
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish build/packages/depla"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/depla/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/depla/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  },
  "tags": []
}
