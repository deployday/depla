[build]
  command = "npm ci --include=dev && DATABASE_URL='file:./prod.db' npx nx setup-prisma <%= app.name %> && DATABASE_URL='file:./prod.db' npx nx build <%= app.name %>"
  functions = "apps/<%= app.name %>/netlify/functions"
  publish = "dist/apps/<%= app.name %>"

[build.environment]
  NODE_VERSION = "16.16.0"

[functions]
  node_bundler = "esbuild"
  included_files = ["apps/<%= app.name %>/netlify/functions/*.wasm"]
  external_node_modules = ["svgo"]
