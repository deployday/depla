import { app } from '<%= workspace.scope %>/shared/app';

<% if (locals.injects) { %><% injects.providers.forEach(function(provider) { %>
import { provider as <%= provider.name %>Provider } from '<%= provider.module %>';
<% }) %><% } %>
<% if (locals.injects) { %>
<% injects.providers.forEach(function(provider) { %>
<%= provider.name %>Provider(app);
<% }) %>
<% } %>

export { app };
