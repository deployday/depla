import { app } from '<%= workspace.scope %>/shared/app';
<% if (locals.injects) { %>
  <% injects.providers.forEach(function(provider) { %>
  import { provider as <%= provider.name %> } from '<%= provider.module %>';
  <% }) %>
<% } %>
import { collectionsProvider } from '@depla/utils-astro-collections-facade';

collectionsProvider(app);
<% if (locals.injects) { %>
<% injects.providers.forEach(function(provider) { %>
<%= provider.name %>(app);
<% }) %>
<% } %>

export { app };
