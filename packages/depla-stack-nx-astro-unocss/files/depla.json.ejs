{
  "entities": <%- JSON.stringify(entities, null, 4) %>,
  "relationships": [],
  "workspaces": [{
    "name": "<%= name %>",
    "slices": [
      "@depla/slice-nx-workspace@latest",
      "@depla/slice-data@latest"
    ],
    "apps": [
      {
        "name": "website",
        "entities": "*",
        "slices": [
          {
            "name": "@depla/slice-astro-app@latest",
            "features": [
              {
                "name": "homepage",
                "path": "/",
                "file": "index.astro"
              },
              {
                "name": "legal pages",
                "pages": [
                  {
                    "path": "/terms"
                  },
                  {
                    "path": "/privacy"
                  }
                ]
              },
              {
                "name": "blog",
                "paths": [
                  {
                    "entity": "post",
                    "path": "/blog",
                    "type": "list",
                    "noindex": false
                  },
                  {
                    "entity": "post",
                    "type": "view",
                    "path": "/%year%/%slug%"
                  },
                  {
                    "entity": "tag",
                    "type": "list",
                    "path": "/blog/tags/",
                    "itemsPerPage": 4
                  },
                  {
                    "entity": "tag",
                    "type": "view",
                    "path": "/blog/tags/%slug%",
                    "noindex": false
                  }
                ]
              }
            ]
          },
          "@depla/slice-config"
        ]
      }
    ]
  }]
}
